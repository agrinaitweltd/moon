ething went wrong while submitting the form.</div></div></div></div></div></div><div class=\"newsletter_shape-wrapper\"><div lottie=\"target\" class=\"newsletter_shape\" data-w-id=\"03d2f708-59e6-5ee8-df17-c4206e304fd5\" data-animation-type=\"lottie\" data-src=\"/assets/69db9824440585a4bf466988_V_Yellow.json\" data-loop=\"0\" data-direction=\"1\" data-autoplay=\"1\" data-is-ix2-target=\"0\" data-renderer=\"svg\" data-default-duration=\"0\" data-duration=\"0\" data-loading=\"lazy\"></div></div></div></div></div></div></div>"}]}
