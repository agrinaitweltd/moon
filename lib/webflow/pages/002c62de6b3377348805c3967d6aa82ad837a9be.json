v><div btn-arrow=\"right\" class=\"arrow is-button\"><div class=\"icon-embed-xsmall w-embed\"><svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" aria-hidden=\"true\" role=\"img\" class=\"iconify iconify--ic\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 24 24\"><path fill=\"currentColor\" d=\"M5 13h11.17l-4.88 4.88c-.39.39-.39 1.03 0 1.42s1.02.39 1.41 0l6.59-6.59a.996.996 0 0 0 0-1.41l-6.58-6.6a.996.996 0 1 0-1.41 1.41L16.17 11H5c-.55 0-1 .45-1 1s.45 1 1 1\"></path></svg></div></div></a></div></div><section data-wf--text-image--variant=\"left-aligned\" class=\"section_text\"><div class=\"padding-global\"><div class=\"container-large\"><div class=\"padding-section-large\"><div class=\"text-image_component\"><div class=\"w-layout-grid text-image_content\"><div class=\"text-image_content-left\"><div class=\"margin-bottom margin-small\"><h2 data-scroll=\"\" class=\"heading-style-h2\">We&#x27;re committed to a better future</h2></div><p class=\"text-size-medium\">Our Environmental, Social, and Governance (ESG) responsibilities are embedded into the way we operate; from reducing our environmental footprint to supporting our people, clients, and communities. We&#x27;re proud to foster a culture that champions sustainability, inclusivity and integrity. It&#x27;s not just what we do, it&#x27;s who we are.</p><div class=\"margin-top margin-medium\"><div class=\"button-group\"><a data-theme=\"dark\" data-btn-hover=\"\" href=\"/esg\" class=\"btn w-inline-block\"><div class=\"btn__bg dark\"></div><div class=\"btn__circle-wrap\"><div class=\"btn__circle dark\"><div class=\"before__100\"></div></div></div><div class=\"btn__text dark\"><p class=\"btn-text-p\">View our statement</p></div></a></div></div></div><div data-scroll-speed=\"-0.05\" data-scroll=\"\" id=\"w-node-_493cfd56-379e-d2f4-3996-15b467d323f6-67d323e4\" class=\"text-image_image-wrapper\"><img data-scroll=\"\" data-scroll-speed=\"-0.05\" alt=\"\" src=\"/assets/6a2183a06db4a86545768474_ChatGPT-Image-Jun-4-2026-02_54_23-PM.avif\" loading=\"lazy\" class=\"image is-parallax\"></div></div></div></div></div></div></section>"}]}
