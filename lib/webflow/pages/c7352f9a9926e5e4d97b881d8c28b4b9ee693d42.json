 \"name\": \"\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"\"\n        }\n      },\n      {\n        \"@type\": \"Question\",\n        \"name\": \"\",\n        \"acceptedAnswer\": {\n          \"@type\": \"Answer\",\n          \"text\": \"\"\n        }\n      }\n    ]\n  }\n}"]},"blocks":[{"tag":"main","attrs":{"className":"main-wrapper"},"html":"<header data-wf--02-standard-header--variant=\"dark\" data-wf-component-id=\"949280b8-8e72-c6a2-5bfc-7cfb2eeda9b8\" data-wf-variant-state=\"8c1228b1-e5f0-eb03-34af-789b7e070b17\" class=\"section_header w-variant-8c1228b1-e5f0-eb03-34af-789b7e070b17\"><div class=\"padding-global is-page-top\"><div class=\"container-large\"><div class=\"simple_header-component\"><div class=\"padding-section-large\"><div class=\"simple_header_grid\"><div id=\"w-node-_8b2fa05c-57cd-b490-ced6-6fac2cf8719e-2eeda9b8\" class=\"simple_header_grid-left\"><div class=\"margin-bottom margin-small\"><h1 class=\"heading-style-h1\">Extending your Lease </h1></div><p class=\"text-size-medium\">If your lease is starting to run down, now is the time to act. Letting it drop below 80 years could significantly increase the cost to extend it. We can help you secure a longer lease that protects the value of your home and gives you peace of mind.</p><div class=\"margin-top margin-medium\"><div class=\"button-group\"><a arrow-rotate=\"trigger\" data-btn-hover=\"\" data-theme=\"primary\" href=\"/contact\" class=\"btn is-icon w-inline-block\"><div class=\"btn__bg\"></div><div class=\"btn__circle-wrap\"><div class=\"btn__circle\"><div class=\"before__100\"></div></div></div><div class=\"btn__text\"><p class=\"btn-text-p\">Speak to an expert</p></div><div btn-arrow=\"right\" class=\"arrow is-button\"><div class=\"icon-embed-xsmall w-embed\"><svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" aria-hidden=\"true\" role=\"img\" class=\"iconify iconify--ic\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 24 24\"><path fill=\"currentColor\" d=\"M5 13h11.17l-4.88 4.88c-.39.39-.39 1.03 0 1.42s1.02.39 1.41 0l6.59-6.59a.996.996 0 0 0 0-1.41l-6.58-6.6a.996.996 0 1 0-1.41 1.41L16.17 11H5c-.55 0-1 .45-1 1s.45 1 1 1\"></path></svg></div></div></a></div></div></div><div id=\"w-node-_8b2fa05c-57cd-b490-ced6-6fac2cf871aa-2eeda9b8\" class=\"simple_header_grid-right\"><div class=\"simple-header_image-wrapper\"><img loading=\"eager\" alt=\"Grey image placeholder with image icon centralised\" class=\"simple-header_image\" src=\"/assets/1.png\"></div></div></div></div></div></div><div class=\"divider-horizontal\"></div><div class=\"container-large\"><div class=\"simple_header-component\"><div class=\"padding-section-xsmall\"><div class=\"breadcrumb_component\"><div data-wf--breadcrumb-original--variant=\"base\" class=\"breadcrumb_component\"><div class=\"breadcrumb_div\"><a href=\"/\" class=\"breadcrumb_link w-inline-block\"><div class=\"breadcrumb_page\">Home</div></a><div class=\"breadcrumb_icon w-embed\"><svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" aria-hidden=\"true\" role=\"img\" class=\"iconify iconify--ic\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 24 24\"><path fill=\"currentColor\" d=\"M5 13h11.17l-4.88 4.88c-.39.39-.39 1.03 0 1.42s1.02.39 1.41 0l6.59-6.59a.996.996 0 0 0 0-1.41l-6.58-6.6a.996.996 0 1 0-1.41 1.41L16.17 11H5c-.55 0-1 .45-1 1s.45 1 1 1\"></path></svg></div></div><div class=\"breadcrumb_div\"><a href=\"/for-individuals\" class=\"breadcrumb_link w-inline-block\"><div class=\"breadcrumb_page\">For individuals</div></a><div class=\"breadcrumb_icon w-embed\"><svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" aria-hidden=\"true\" role=\"img\" class=\"iconify iconify--ic\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 24 24\"><path fill=\"currentColor\" d=\"M5 13h11.17l-4.88 4.88c-.39.39-.39 1.03 0 1.42s1.02.39 1.41 0l6.59-6.59a.996.996 0 0 0 0-1.41l-6.58-6.6a.996.996 0 1 0-1.41 1.41L16.17 11H5c-.55 0-1 .45-1 1s.45 1 1 1\"></path></svg></div></div><div class=\"breadcrumb_div\"><div class=\"breadcrumb_current-page\">Extending your Lease </div></div></div></div></div></div></div></div><div class=\"listing_shape-wrapper w-variant-8c1228b1-e5f0-eb03-34af-789b7e070b17\"><div lottie=\"target-load\" class=\"header_shape is-standard\" data-w-id=\"5d828c84-1f1c-1e38-bfb3-80ffb8d04940\" data-animation-type=\"lottie\" data-src=\"https://cdn.prod.website-files.com/68b448d2e0ae8eda7aa370e3/69db9824cf9ff19dd03c1c29_08fdbca2c62ae345f765f433c8401fe4_Blacks_V_Blue.json\" data-loop=\"0\" data-direction=\"1\" data-autoplay=\"1\" data-is-ix2-target=\"0\" data-renderer=\"svg\" data-default-duration=\"0\" data-duration=\"0\" data-loading=\"lazy\"></div></div><div class=\"simple-header_background-image-wrapper\"><div class=\"image-overlay-layer\"></div><img loading=\"eager\" alt=\"Grey image placeholder with image icon centralised\" class=\"simple-header_background-image\" src=\"/assets/1.png\"></div></header><section class=\"section_benefit-grid_layout\"><div class=\"padding-global\"><div class=\"container-large\"><div class=\"padding-section-large\"><div class=\"benefit-grid_component\"><div class=\"w-layout-grid benefit-grid_list\"><div class=\"benefit-grid_item\"><div class=\"w-richtext\"><h4>Informal lease extension</h4><p>You can agree on the new lease term, ground rent, and premium directly with your landlord. It’s flexible but less protected. You’ll pay the landlord’s legal and valuation costs as well as your own.</p><p>‍</p></div></div><div class=\"benefit-grid_item\"><div class=\"w-richtext\"><h4>Statutory lease extension</h4><p>This route gives you a 90-year extension on top of your remaining lease term, with ground rent reduced to zero (becomes a peppercorn). You must qualify legally and follow the formal process. You’ll cover both sides’ legal and valuation fees.</p><p>‍</p></div></div><div class=\"benefit-grid_item\"><div class=\"w-richtext\"><h4>Section 42 Notice</h4><p>Serving this notice starts the formal lease extension process. It’s the first step if you want statutory protection.</p><p>‍</p></div></div><div class=\"benefit-grid_item\"><div class=\"w-richtext\"><h4>Assignment of Section 42 Notice</h4><p>If you’re selling your home, you can serve the Section 42 notice and pass the benefit to the buyer, helping you sell with confidence.</p><p>‍</p></div></div><div class=\"benefit-grid_item\"><div class=\"w-richtext\"><h4>Missing landlord application</h4><p>If your landlord can’t be found, we can guide you through the court process to extend your lease without their direct involvement.</p><p>‍</p></div></div><div class=\"benefit-grid_item\"><div class=\"w-richtext\"><h4>Ground rent issues</h4><p>A statutory lease extension removes your ground rent entirely, solving issues with escalating or unfair ground rent clauses.</p><p>‍</p></div></div><div class=\"benefit-grid_item w-condition-invisible\"><div class=\"w-dyn-bind-empty w-richtext\"></div></div><div class=\"benefit-grid_item w-condition-invisible\"><div class=\"w-dyn-bind-empty w-richtext\"></div></div><div class=\"benefit-grid_item w-condition-invisible\"><div class=\"w-dyn-bind-empty w-richtext\"></div></div></div></div></div></div></div></section><section class=\"section_accordion\"><div class=\"padding-global\"><div class=\"container-large\"><div class=\"padding-section-large\"><div class=\"faq6_component\"><div class=\"w-layout-grid faq6_content\"><div class=\"faq6_content-left\"><h2>Questions we’re often asked</h2><div class=\"margin-top margin-small\"><div class=\"button-group\"><a href=\"/contact\" class=\"button is-secondary w-button\">Speak to an expert</a></div></div></div><div class=\"faq6_list\"><div class=\"w-layout-grid faq6_list-grid\"><div class=\"faq6_accordion\"><div data-w-id=\"2d4f5f46-8657-6adf-b3b2-ede2787f7f7d\" class=\"faq6_question\"><div>Can my solicitor negotiate the premium for my lease extension with the landlord?</div><div class=\"faq6_icon-wrapper\"><div class=\"icon-embed-small w-embed\"><svg width=\"100%\" height=\"100%\" viewBox=\"0 0 32 32\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M25.3333 15.667V16.3336C25.3333 16.7018 25.0349 17.0003 24.6667 17.0003H17V24.667C17 25.0351 16.7015 25.3336 16.3333 25.3336H15.6667C15.2985 25.3336 15 25.0351 15 24.667V17.0003H7.3333C6.96511 17.0003 6.66663 16.7018 6.66663 16.3336V15.667C6.66663 15.2988 6.96511 15.0003 7.3333 15.0003H15V7.33365C15 6.96546 15.2985 6.66699 15.6667 6.66699H16.3333C16.7015 6.66699 17 6.96546 17 7.33365V15.0003H24.6667C25.0349 15.0003 25.3333 15.2988 25.3333 15.667Z\" fill=\"currentColor\"></path>\n</svg></div></div></div><div class=\"faq6_answer\"><div class=\"margin-bottom margin-small\"><div class=\"max-width-large\"><p>This is a valuer’s job, and you will need to instruct an enfranchisement valuer. We can provide contact details for enfranchisement valuers that we work with. </p></div></div></div></div><div class=\"faq6_accordion\"><div data-w-id=\"2d4f5f46-8657-6adf-b3b2-ede2787f7f88\" class=\"faq6_question\"><div>I recently had a valuation carried out for my remortgage or purchase, can I use that for the statutory lease extension?</div><div class=\"faq6_icon-wrapper\"><div class=\"icon-embed-small w-embed\"><svg width=\"100%\" height=\"100%\" viewBox=\"0 0 32 32\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M25.3333 15.667V16.3336C25.3333 16.7018 25.0349 17.0003 24.6667 17.0003H17V24.667C17 25.0351 16.7015 25.3336 16.3333 25.3336H15.6667C15.2985 25.3336 15 25.0351 15 24.667V17.0003H7.3333C6.96511 17.0003 6.66663 16.7018 6.66663 16.3336V15.667C6.66663 15.2988 6.96511 15.0003 7.3333 15.0003H15V7.33365C15 6.96546 15.2985 6.66699 15.6667 6.66699H16.3333C16.7015 6.66699 17 6.96546 17 7.33365V15.0003H24.6667C25.0349 15.0003 25.3333 15.2988 25.3333 15.667Z\" fill=\"currentColor\"></path>\n</svg></div></div></div><div class=\"faq6_answer\"><div class=\"margin-bottom margin-small\"><div class=\"max-width-large\"><p>No. You need to commission an enfranchisement valuation which will give you the premium/ price to propose for the statutory lease extension. </p></div></div></div></div><div class=\"faq6_accordion\"><div data-w-id=\"2d4f5f46-8657-6adf-b3b2-ede2787f7f93\" class=\"faq6_question\"><div>How long does a statutory lease extension take?</div><div class=\"faq6_icon-wrapper\"><div class=\"icon-embed-small w-embed\"><svg width=\"100%\" height=\"100%\" viewBox=\"0 0 32 32\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<path d=\"M25.3333 15.667V16.3336C25.3333 16.7018 25.0349 17.0003 24.6667 17.0003H17V24.667C17 25.0351 16.7015 25.3336 16.3333 25.3336H15.6667C15.2985 25.3336 15 25.0351 15 24.667V17.0003H7.3333C6.96511 17.0003 6.66663 16.7018 6.66663 16.3336V15.667C6.66663 15.2988 6.96511 15.0003 7.3333 15.0003H15V7.33365C15 6.96546 15.2985 6.66699 15.6667 6.66699H16.3333C16.7015 6.66699 17 6.96546 17 7.33365V15.0003H24.6667C25.0349 15.0003 25.3333 15.2988 25.3333 15.667Z\" fill=\"currentColor\"></path>\n</svg></div></div></div><div class=\"faq6_answer\"><div class=\"margin-bottom margin-small\"><div class=\"max-width-large\"><p>There are statutory timescales to adhere to, and a statutory lease extension can take between 8-12 months to complete. </p></div></div></div></div></div></div></div></div></div></div></div></section><div class=\"section_testimonial\"><div class=\"w-embed\"><style>\n.section_testimonial:has(.w-dyn-empty) {\n  display: none;\n}\n</style></div><div class=\"padding-section-large\"><div class=\"divider-horizontal\"></div><div class=\"padding-global\"><div class=\"container-large\"><div fs-slider-type=\"cms\" fs-slider-instance=\"fs-1-card-slider\" class=\"fs-1-card-slider_instance\"><div class=\"fs-1-card-slider_navigation-wrapper\"><div class=\"testimonial_icon-wrapper\"><img loading=\"lazy\" alt=\"\" class=\"testimonial_icon\" src=\"/assets/69010fb7542aa2ee07e42406_quote-2.svg\"></div><div fs-slider-element=\"navigation\" class=\"fs-1-card-slider_navigation\"><button fs-slider-element=\"previous\" class=\"fs-1-card-slider_button\"><div class=\"icon-embed-small w-embed\"><svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" aria-hidden=\"true\" role=\"img\" class=\"iconify iconify--ic\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 24 24\"><path fill=\"currentColor\" d=\"M14.71 15.88L10.83 12l3.88-3.88a.996.996 0 1 0-1.41-1.41L8.71 11.3a.996.996 0 0 0 0 1.41l4.59 4.59c.39.39 1.02.39 1.41 0c.38-.39.39-1.03 0-1.42\"></path></svg></div></button><button fs-slider-element=\"next\" class=\"fs-1-card-slider_button\"><div class=\"icon-embed-small w-embed\"><svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" aria-hidden=\"true\" role=\"img\" class=\"iconify iconify--ic\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 24 24\"><path fill=\"currentColor\" d=\"M9.29 15.88L13.17 12L9.29 8.12a.996.996 0 1 1 1.41-1.41l4.59 4.59c.39.39.39 1.02 0 1.41L10.7 17.3a.996.996 0 0 1-1.41 0c-.38-.39-.39-1.03 0-1.42\"></path></svg></div></button></div></div><div fs-slider-element=\"list-wrapper\" class=\"fs-1-card-slider_list-wrapper w-dyn-list\"><div fs-slider-element=\"list\" role=\"list\" class=\"fs-1-card-slider_list w-dyn-items\"><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">Thank you Anushka and all your team for looking after us so well and protecting our interests. It’s made potentially stressful situations straightforward. Very much appreciated.</div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Leasehold Enfranchisement Client </div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">I was impressed by the team at Moonstone Advocates. Every member of staff I dealt with was pleasant and professional, demonstrating a clear commitment to helping me rather than just driving up costs.</div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Moonstone Client</div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">My first time using Moonstone, I&#x27;ve used a few solicitors over time, working with team at Moonstone has been effortless and efficient, I would be happy to recommend and use again.</div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Moonstone Client </div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">It’s clear that client care and hospitality are taken seriously here. I would highly recommend Moonstone to anyone looking for a professional, welcoming and experienced legal firm.</div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Moonstone Client </div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">Very impressed with their experience from start to finish. The legal team were exceptionally friendly, welcoming, and professional throughout. The security staff were particularly polite and approachable, making visitors feel comfortable as soon as they arrived. </div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Moonstone Client </div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">I would have no hesitation in recommending Anushka and the Leasehold team to anyone seeking specialist leasehold advice and assistance.</div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Leasehold Enfranchisement Client</div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">Anushka and her colleagues were always professional, approachable and responsive, making what can often be a complex and time-consuming process feel straightforward and well managed. Their dedication to achieving positive outcomes for their clients was evident throughout.</div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Leasehold Enfranchisement Client</div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">The team demonstrated great knowledge and expertise throughout the process. As we were managing multiple lease extensions simultaneously, their organisation, efficiency and attention to detail were invaluable.</div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Leasehold Enfranchisement Client </div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">I have had the pleasure of working with Anushka and the Leasehold Team on several lease extension matters, and I highly recommend them - fantastic team! </div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Leasehold Enfranchisement Client </div></div></div></div><div fs-slider-element=\"slide\" role=\"listitem\" class=\"fs-1-card-slider_slide w-dyn-item\"><div class=\"heading-style-h6\">Trusted by organisations, families and professionals across Uganda</div><div class=\"heading-style-h4\">Moonstone Advocates and Julie Powell in particular was a huge help with one of our client&#x27;s lease extension processes. She handled everything smoothly and kept communication clear and consistent throughout. Her proactive approach really made things easier for everyone involved. Great to work with and I look forward to working with her in the future.</div><div class=\"testimonial_attribute\"><div class=\"testimonial_personal-details\"><div class=\"text-weight-semibold\">Leasehold Enfranchisement Client</div></div></div></div></div></div></div></div></div></div></div><div element-reveal=\"trigger\" class=\"section_team\"><div class=\"padding-global\"><div class=\"container-large\"><div class=\"padding-se